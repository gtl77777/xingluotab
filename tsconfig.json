{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "entrypoints",
    "src",
    "tests",
    "wxt.config.ts",
    "tailwind.config.ts",
    "postcss.config.js"
  ]
}
